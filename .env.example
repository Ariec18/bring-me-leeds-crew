# ─── LLM ─────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# Или Anthropic:
# ANTHROPIC_API_KEY=sk-ant-...
# MODEL=anthropic/claude-sonnet-4-20250514

# ─── Search (Serper.dev) ──────────────────────────────────────
# 2500 бесплатных запросов: https://serper.dev
SERPER_API_KEY=...

# ─── Email ────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password   # Gmail App Password (не обычный пароль!)
FROM_EMAIL=your-email@gmail.com

# ─── GitHub (для деплоя демо-сайтов на GitHub Pages) ─────────
GITHUB_TOKEN=ghp_...
GITHUB_REPO=Ariec18/bring-me-leeds-crew

# ─── Pipeline settings ────────────────────────────────────────
TARGET_LOCATION=Koh Samui, Thailand
TARGET_BUSINESS_TYPE=restaurants
MAX_LEADS=20
MAX_EMAILS_PER_RUN=10
